<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Yonetimi | Sporthink</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        body { background-color: #0f172a; color: #f8fafc; }
        .glass-panel { background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 1rem; }
    </style>
</head>
<body class="flex h-screen overflow-hidden text-slate-200">
    <aside class="w-64 bg-slate-900 border-r border-slate-700 flex flex-col hidden md:flex">
        <div class="h-16 flex items-center justify-center border-b border-slate-700">
            <h1 class="text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-teal-400 to-blue-500">Sporthink Panel</h1>
        </div>
                        <nav class="flex-1 p-4 space-y-2 overflow-y-auto">
            <a href="/admin" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-home w-6"></i> Dashboard</a>
            <a href="/admin/products" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-shopping-bag w-6"></i> Ürünler (Dükkan)</a>
            <a href="/admin/chests" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-box-open w-6"></i> Sandık Sistemi</a>
            <a href="/admin/users" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-users w-6"></i> Kullanıcılar</a>
            <a href="/admin/stats" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-chart-line w-6"></i> İstatistik ve Loglar</a>
            <a href="/admin/notifications" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-bell w-6"></i> Bildirimler</a>
            <a href="/admin/tips" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-lightbulb w-6"></i> İpuçları (Tips)</a>
            <a href="/admin/settings" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-cogs w-6"></i> Ayarlar</a>
            <a href="/admin/badges" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-award w-6"></i> Rozetler (Badges)</a>
            <a href="/admin/avatar-items" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-user-astronaut w-6"></i> Avatar Parçaları</a>
            <a href="/admin/admins" class="flex items-center px-4 py-3 bg-gradient-to-r from-teal-500/20 to-blue-500/20 text-teal-300 border border-teal-500/30 rounded-lg transition-colors"><i class="fas fa-user-shield w-6"></i> Admin Yönetimi</a>
        </nav>
    </aside>
    <main class="flex-1 flex flex-col bg-slate-900 overflow-y-auto">
        <header class="h-16 flex items-center justify-between px-8 border-b border-slate-700 glass-panel sticky top-0 z-10 rounded-none border-t-0 border-l-0 border-r-0">
            <h2 class="text-xl font-semibold"><i class="fas fa-user-shield mr-2 text-purple-400"></i> Admin Yonetimi</h2>
            <a href="/admin/logout" class="text-sm text-red-400 hover:text-red-300"><i class="fas fa-sign-out-alt mr-1"></i> Cikis</a>
        </header>
        <div class="p-8 space-y-6">
            <div class="glass-panel p-6 border border-purple-500/20">
                <h3 class="text-lg font-bold text-purple-400 mb-4"><i class="fas fa-plus mr-2"></i> Yeni Admin Olustur</h3>
                <form action="/admin/admins/create" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm text-slate-300 mb-1">Ad</label>
                        <input type="text" name="first_name" required class="w-full bg-slate-900 border border-slate-600 rounded px-3 py-2 text-white">
                    </div>
                    <div>
                        <label class="block text-sm text-slate-300 mb-1">Soyad</label>
                        <input type="text" name="last_name" required class="w-full bg-slate-900 border border-slate-600 rounded px-3 py-2 text-white">
                    </div>
                    <div>
                        <label class="block text-sm text-slate-300 mb-1">Kullanici Adi</label>
                        <input type="text" name="username" required class="w-full bg-slate-900 border border-slate-600 rounded px-3 py-2 text-white">
                    </div>
                    <div>
                        <label class="block text-sm text-slate-300 mb-1">Sifre</label>
                        <input type="password" name="password" required minlength="6" class="w-full bg-slate-900 border border-slate-600 rounded px-3 py-2 text-white">
                    </div>
                    <div class="md:col-span-2">
                        <button type="submit" class="bg-purple-600 hover:bg-purple-700 text-white px-6 py-2 rounded font-bold transition-colors"><i class="fas fa-plus mr-2"></i> Olustur</button>
                    </div>
                </form>
            </div>
            <div class="glass-panel overflow-hidden border border-slate-700">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-800/50 border-b border-slate-700 text-slate-400 text-sm">
                            <th class="p-4 font-medium">Ad Soyad</th>
                            <th class="p-4 font-medium">Kullanici Adi</th>
                            <th class="p-4 font-medium">Kayit Tarihi</th>
                            <th class="p-4 font-medium text-right">Islem</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-700/50 text-sm">
                        <% admins.forEach(admin => { %>
                            <tr class="hover:bg-slate-800/50">
                                <td class="p-4 font-bold text-slate-200"><%= admin.first_name %> <%= admin.last_name %></td>
                                <td class="p-4 text-slate-400"><%= admin.username %></td>
                                <td class="p-4 text-slate-500 text-xs"><%= admin.created_at ? new Date(admin.created_at).toLocaleDateString('tr-TR') : '-' %></td>
                                <td class="p-4 text-right">
                                    <% if (admin.id !== currentAdminId) { %>
                                        <form action="/admin/admins/delete" method="POST" class="inline" onsubmit="return confirm('Bu admini silmek istediginize emin misiniz?')">
                                            <input type="hidden" name="admin_id" value="<%= admin.id %>">
                                            <button class="text-red-400 bg-red-500/10 hover:bg-red-500/20 px-3 py-1.5 rounded border border-red-500/30"><i class="fas fa-trash"></i></button>
                                        </form>
                                    <% } else { %>
                                        <span class="text-xs text-slate-500">(Sen)</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</body>
</html>
