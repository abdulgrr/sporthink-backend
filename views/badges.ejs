<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Rozet Yönetimi | Sporthink Gamification</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        body { background-color: #0f172a; color: #f8fafc; }
        .glass-panel { background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 1rem; }
    </style>
</head>
<body class="flex h-screen overflow-hidden text-slate-200">
    <!-- SOL MENÜ -->
    <aside class="w-64 bg-slate-900 border-r border-slate-700 flex flex-col hidden md:flex">
        <div class="h-16 flex items-center justify-center border-b border-slate-700">
            <h1 class="text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-teal-400 to-blue-500">Sporthink Panel</h1>
        </div>
        <nav class="flex-1 p-4 space-y-2 overflow-y-auto">
            <a href="/admin" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-home w-6"></i> Dashboard</a>
            <a href="/admin/products" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-shopping-bag w-6"></i> Ürünler (Dükkan)</a>
            <a href="/admin/chests" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-box-open w-6"></i> Sandık Sistemi</a>
            <a href="/admin/users" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-users w-6"></i> Kullanıcılar</a>
            <a href="/admin/stats" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-chart-line w-6"></i> İstatistik ve Loglar</a>
            <a href="/admin/notifications" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-bell w-6"></i> Bildirimler</a>
            <a href="/admin/tips" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-lightbulb w-6"></i> İpuçları (Tips)</a>
            <a href="/admin/settings" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-cogs w-6"></i> Ayarlar</a>
            <a href="/admin/badges" class="flex items-center px-4 py-3 bg-gradient-to-r from-teal-500/20 to-blue-500/20 text-teal-300 border border-teal-500/30 rounded-lg transition-colors"><i class="fas fa-award w-6"></i> Rozetler (Badges)</a>
            <a href="/admin/avatar-items" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-user-astronaut w-6"></i> Avatar Parçaları</a>
            <a href="/admin/admins" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-user-shield w-6"></i> Admin Yönetimi</a>
        </nav>
    </aside>

    <!-- ANA İÇERİK -->
    <main class="flex-1 flex flex-col bg-slate-900 overflow-y-auto">
        <header class="h-16 flex items-center justify-between px-8 border-b border-slate-700 glass-panel sticky top-0 z-10 rounded-none border-t-0 border-l-0 border-r-0">
            <h2 class="text-xl font-semibold"><i class="fas fa-award mr-2 text-yellow-400"></i> Rozet Yönetimi</h2>
            <div class="flex items-center space-x-4">
                <span class="text-sm text-slate-400"><i class="fas fa-user-shield mr-1"></i> Admin</span>
                <a href="/admin/logout" class="text-sm text-red-400 hover:text-red-300 transition-colors">
                    <i class="fas fa-sign-out-alt mr-1"></i> Çıkış
                </a>
            </div>
        </header>

        <div class="p-8 space-y-6">
            <!-- Rozet Ekleme Formu -->
            <div class="glass-panel p-6 border border-slate-700">
                <h3 class="text-xl font-bold mb-6 text-white border-b border-slate-700 pb-2"><i class="fas fa-plus-circle text-green-400"></i> Yeni Rozet Tanımla</h3>
                
                <form action="/admin/badges/add" method="POST" enctype="multipart/form-data" class="space-y-4">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium mb-1 text-slate-300">Rozet Adı</label>
                            <input type="text" name="name" required class="w-full px-4 py-2 border border-slate-600 rounded drop-shadow bg-slate-800 text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Örn: 100K Adım Ustası">
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-1 text-slate-300">Açıklama</label>
                            <input type="text" name="description" required class="w-full px-4 py-2 border border-slate-600 rounded drop-shadow bg-slate-800 text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Rozet ne için kazanılıyor?">
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-1 text-slate-300">Kazanma Şartı (Sistem Türü)</label>
                            <select name="requirement_type" class="w-full px-4 py-2 border border-slate-600 rounded drop-shadow bg-slate-800 text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500">
                                <option value="streak_days">💥 Streak Günü Sınırı</option>
                                <option value="total_points">🪙 Toplam Hayat Boyu Puan</option>
                                <option value="weekly_steps">📅 1 Haftada Atılan Adım (Mevcut Hafta)</option>
                                <option value="chests_opened">📦 Açılan Sandık Sayısı</option>
                                <option value="weekly_rank">👑 Haftalık Sıralama (1. veya ilk 3 vb.)</option>
                                <option value="follower_count">👥 Takipçi Sayısı</option>
                                <option value="daily_steps">👟 Günlük Adım (Tek Seferde)</option>
                                <option value="xp_level">⭐ XP Seviyesi (Level)</option>
                                <option value="quests_completed">🎯 Tamamlanan Görev Sayısı</option>
                                <option value="total_likes_received">❤️ Alınan Toplam Beğeni</option>
                                <option value="total_comments_made">💬 Yapılan Toplam Yorum</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-1 text-slate-300">Hedef Sayı Değeri (Örn: 5)</label>
                            <input type="number" name="requirement_value" required min="1" class="w-full px-4 py-2 border border-slate-600 rounded drop-shadow bg-slate-800 text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Sadece sayı girin">
                        </div>
                        <div class="md:col-span-2">
                            <label class="block text-sm font-medium mb-1 text-slate-300">Rozet Görseli Yükle (PC'den Seçin)</label>
                            <input type="file" name="badgeImage" accept="image/*" required class="w-full px-4 py-2 text-sm text-slate-300 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-600 file:text-blue-100 hover:file:bg-blue-700 bg-slate-800 border-slate-600 border rounded cursor-pointer">
                        </div>
                    </div>
                    <button type="submit" class="mt-4 px-6 py-2 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-500 hover:to-indigo-500 text-white font-bold rounded shadow transition-all">Rozeti Ekle</button>
                </form>
            </div>

            <!-- Rozet Listesi -->
            <div class="glass-panel p-6 border border-slate-700">
                <h3 class="text-xl font-bold mb-4 text-white"><i class="fas fa-list text-purple-400"></i> Aktif Rozetler</h3>
                
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-4">
                    <% if (badges && badges.length > 0) { %>
                        <% badges.forEach(badge => { %>
                            <div class="bg-slate-800 rounded-xl overflow-hidden shadow-lg border border-slate-700 flex flex-col transition-transform hover:scale-105">
                                <div class="h-40 bg-slate-700 flex items-center justify-center p-4">
                                    <img src="<%- badge.image_url %>" alt="Rozet Görseli" class="max-h-full object-contain drop-shadow-2xl">
                                </div>
                                <div class="p-4 flex-1">
                                    <h4 class="text-lg font-bold text-yellow-400"><%- badge.name %></h4>
                                    <p class="text-sm text-slate-400 mt-1"><%- badge.description %></p>
                                    <div class="mt-3 bg-slate-900 rounded p-2 text-xs border border-slate-700">
                                        <span class="text-indigo-400 font-bold block mb-1">Kazanma Kuralı:</span>
                                        <span class="text-slate-300">Tipi: <b class="text-green-400"><%- badge.requirement_type %></b></span><br>
                                        <span class="text-slate-300">Değer: <b class="text-blue-400"><%- badge.requirement_value %></b></span>
                                    </div>
                                </div>
                                <form action="/admin/badges/delete/<%- badge.id %>" method="POST" class="p-4 pt-0">
                                    <button type="submit" class="w-full text-red-500 hover:text-red-400 font-medium py-2 rounded border border-red-500/50 hover:bg-red-500/10 transition-colors" onclick="return confirm('Bu rozet tamamen silinecek! Devam edilsin mi?');">
                                        <i class="fas fa-trash-alt"></i> Rozeti Kaldır
                                    </button>
                                </form>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="col-span-full p-8 text-center text-slate-500 bg-slate-800/50 rounded-lg border border-slate-700 border-dashed">
                            <i class="fas fa-medal text-4xl mb-3 text-slate-600"></i>
                            <p>Henüz sisteme rozet yüklenmemiş.</p>
                        </div>
                    <% } %>
                </div>
            </div>
            
        </div>
    </main>
</body>
</html>