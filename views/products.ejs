<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dükkan ve Ürün Yönetimi | Sporthink Gamification</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        body { background-color: #0f172a; color: #f8fafc; }
        .glass-panel { background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 1rem; }
    </style>
</head>
<body class="flex h-screen overflow-hidden text-slate-200">
    <!-- SOL MENÜ -->
    <aside class="w-64 bg-slate-900 border-r border-slate-700 flex flex-col hidden md:flex">
        <div class="h-16 flex items-center justify-center border-b border-slate-700">
            <h1 class="text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-teal-400 to-blue-500">Sporthink Panel</h1>
        </div>
                        <nav class="flex-1 p-4 space-y-2 overflow-y-auto">
            <a href="/admin" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-home w-6"></i> Dashboard</a>
            <a href="/admin/products" class="flex items-center px-4 py-3 bg-gradient-to-r from-teal-500/20 to-blue-500/20 text-teal-300 border border-teal-500/30 rounded-lg transition-colors"><i class="fas fa-shopping-bag w-6"></i> Ürünler (Dükkan)</a>
            <a href="/admin/chests" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-box-open w-6"></i> Sandık Sistemi</a>
            <a href="/admin/users" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-users w-6"></i> Kullanıcılar</a>
            <a href="/admin/stats" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-chart-line w-6"></i> İstatistik ve Loglar</a>
            <a href="/admin/notifications" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-bell w-6"></i> Bildirimler</a>
            <a href="/admin/tips" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-lightbulb w-6"></i> İpuçları (Tips)</a>
            <a href="/admin/settings" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-cogs w-6"></i> Ayarlar</a>
            <a href="/admin/badges" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-award w-6"></i> Rozetler (Badges)</a>
            <a href="/admin/avatar-items" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-user-astronaut w-6"></i> Avatar Parçaları</a>
            <a href="/admin/admins" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-user-shield w-6"></i> Admin Yönetimi</a>
        </nav>
    </aside>

    <!-- ANA İÇERİK -->
    <main class="flex-1 flex flex-col bg-slate-900 overflow-y-auto relative">
        <header class="h-16 flex items-center justify-between px-8 border-b border-slate-700 glass-panel sticky top-0 z-10 rounded-none border-t-0 border-l-0 border-r-0">
            <h2 class="text-xl font-semibold"><i class="fas fa-shopping-bag mr-2 text-teal-400"></i> Dükkan & Ürün Yönetimi</h2>
            <div class="flex items-center space-x-4">
                <button onclick="toggleModal('addModal')" class="bg-blue-600 hover:bg-blue-500 text-white px-4 py-2 rounded shadow transition-colors font-medium text-sm">
                    <i class="fas fa-plus mr-1"></i> Yeni Ürün Ekle
                </button>
                <a href="/admin/logout" class="text-sm text-red-400 hover:text-red-300 transition-colors">
                    <i class="fas fa-sign-out-alt mr-1"></i> Çıkış
                </a>
            </div>
        </header>

        <div class="p-8 space-y-6">
            <div class="glass-panel overflow-hidden border border-slate-700">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-slate-800/50 border-b border-slate-700 text-slate-400 text-sm">
                                <th class="p-4 font-medium">#</th>
                                <th class="p-4 font-medium">Görsel</th>
                                <th class="p-4 font-medium">Ürün Adı</th>
                                <th class="p-4 font-medium">Açıklama</th>
                                <th class="p-4 font-medium">Fiyat (Puan)</th>
                                <th class="p-4 font-medium">Durum</th>
                                <th class="p-4 font-medium text-right">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-700/50 text-sm">
                            <% if(products && products.length > 0) { %>
                                <% products.forEach(product => { %>
                                    <tr class="hover:bg-slate-800/50 transition-colors">
                                        <td class="p-4 text-slate-500"><%= product.id %></td>
                                        <td class="p-4">
                                            <% if(product.image_url) { %>
                                                <img src="<%= product.image_url %>" class="w-12 h-12 rounded object-cover border border-slate-600" alt="<%= product.name %>">
                                            <% } else { %>
                                                <div class="w-12 h-12 rounded bg-slate-700 border border-slate-600 flex items-center justify-center text-slate-400 font-bold">?</div>
                                            <% } %>
                                        </td>
                                        <td class="p-4 font-bold text-slate-200"><%= product.name %></td>
                                        <td class="p-4 text-slate-400"><%= product.description ? product.description.substring(0, 30) + '...' : '-' %></td>
                                        <td class="p-4">
                                            <span class="bg-yellow-500/20 text-yellow-300 border border-yellow-500/30 px-2 py-1 rounded font-medium">
                                                <i class="fas fa-coins text-xs mr-1"></i><%= product.price_points %>
                                            </span>
                                        </td>
                                        <td class="p-4">
                                            <% if(product.is_active) { %>
                                                <span class="bg-emerald-500/20 text-emerald-400 border border-emerald-500/30 px-2 py-1 rounded text-xs">Aktif</span>
                                            <% } else { %>
                                                <span class="bg-slate-500/20 text-slate-400 border border-slate-500/30 px-2 py-1 rounded text-xs">Pasif</span>
                                            <% } %>
                                        </td>
                                        <td class="p-4 text-right space-x-2">
                                            <button onclick="openEditModal(<%= JSON.stringify(product) %>)" class="text-blue-400 hover:text-blue-300 transition-colors bg-blue-500/10 hover:bg-blue-500/20 px-3 py-1.5 rounded border border-blue-500/30">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                            <form action="/admin/products/delete/<%= product.id %>" method="POST" class="inline-block" onsubmit="return confirm('Bu ürünü silmek istediğinize emin misiniz?');">
                                                <button type="submit" class="text-red-400 hover:text-red-300 transition-colors bg-red-500/10 hover:bg-red-500/20 px-3 py-1.5 rounded border border-red-500/30">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="7" class="p-8 text-center text-slate-500 italic">Kayıtlı ürün bulunamadı.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Ekleme Modalı -->
        <div id="addModal" class="fixed inset-0 bg-slate-900/80 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4 opacity-0 transition-opacity duration-300">
            <div class="bg-slate-800 border border-slate-600 rounded-xl shadow-2xl w-full max-w-md overflow-hidden transform scale-95 transition-transform duration-300" id="addModalContent">
                <div class="px-6 py-4 border-b border-slate-700 flex justify-between items-center bg-slate-900/50">
                    <h3 class="text-lg font-bold text-white">Yeni Ürün Ekle</h3>
                    <button onclick="toggleModal('addModal')" class="text-slate-400 hover:text-white transition-colors"><i class="fas fa-times text-xl"></i></button>
                </div>
                <form action="/admin/products/add" method="POST" enctype="multipart/form-data" class="p-6 space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-1">Ürün Adı</label>
                        <input type="text" name="name" required class="w-full bg-slate-900 border border-slate-600 rounded px-3 py-2 text-white focus:outline-none focus:border-blue-500">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-1">Açıklama</label>
                        <textarea name="description" rows="3" class="w-full bg-slate-900 border border-slate-600 rounded px-3 py-2 text-white focus:outline-none focus:border-blue-500"></textarea>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-1">Fiyat (Puan)</label>
                        <input type="number" name="price_points" required class="w-full bg-slate-900 border border-slate-600 rounded px-3 py-2 text-white focus:outline-none focus:border-blue-500">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-1">Görsel Yükle (Bilgisayardan)</label>
                        <input type="file" name="productImage" accept="image/*" class="w-full bg-slate-900 border border-slate-600 rounded px-3 py-2 text-white focus:outline-none focus:border-blue-500">
                    </div>
                    <div class="pt-4 flex justify-end space-x-3">
                        <button type="button" onclick="toggleModal('addModal')" class="px-4 py-2 rounded text-slate-300 hover:bg-slate-700 transition-colors">İptal</button>
                        <button type="submit" class="px-4 py-2 rounded bg-blue-600 hover:bg-blue-500 text-white font-medium transition-colors shadow">Kaydet</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Düzenleme Modalı -->
        <div id="editModal" class="fixed inset-0 bg-slate-900/80 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4 opacity-0 transition-opacity duration-300">
            <div class="bg-slate-800 border border-slate-600 rounded-xl shadow-2xl w-full max-w-md overflow-hidden transform scale-95 transition-transform duration-300" id="editModalContent">
                <div class="px-6 py-4 border-b border-slate-700 flex justify-between items-center bg-slate-900/50">
                    <h3 class="text-lg font-bold text-white">Ürünü Düzenle</h3>
                    <button onclick="toggleModal('editModal')" class="text-slate-400 hover:text-white transition-colors"><i class="fas fa-times text-xl"></i></button>
                </div>
                <form id="editForm" method="POST" enctype="multipart/form-data" class="p-6 space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-1">Ürün Adı</label>
                        <input type="text" name="name" id="edit_name" required class="w-full bg-slate-900 border border-slate-600 rounded px-3 py-2 text-white focus:outline-none focus:border-blue-500">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-1">Açıklama</label>
                        <textarea name="description" id="edit_description" rows="3" class="w-full bg-slate-900 border border-slate-600 rounded px-3 py-2 text-white focus:outline-none focus:border-blue-500"></textarea>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-1">Fiyat (Puan)</label>
                        <input type="number" name="price_points" id="edit_price" required class="w-full bg-slate-900 border border-slate-600 rounded px-3 py-2 text-white focus:outline-none focus:border-blue-500">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-1">Yeni Görsel Yükle (Mevcut olanı değiştirmek için)</label>
                        <input type="file" name="productImage" accept="image/*" class="w-full bg-slate-900 border border-slate-600 rounded px-3 py-2 text-white focus:outline-none focus:border-blue-500">
                    </div>
                    <div class="pt-4 flex justify-end space-x-3">
                        <button type="button" onclick="toggleModal('editModal')" class="px-4 py-2 rounded text-slate-300 hover:bg-slate-700 transition-colors">İptal</button>
                        <button type="submit" class="px-4 py-2 rounded bg-blue-600 hover:bg-blue-500 text-white font-medium transition-colors shadow">Güncelle</button>
                    </div>
                </form>
            </div>
        </div>
    </main>

    <script>
        function toggleModal(modalID) {
            const modal = document.getElementById(modalID);
            const content = document.getElementById(modalID + 'Content');
            if (modal.classList.contains('hidden')) {
                modal.classList.remove('hidden');
                // trigger reflow
                void modal.offsetWidth;
                modal.classList.remove('opacity-0');
                content.classList.remove('scale-95');
            } else {
                modal.classList.add('opacity-0');
                content.classList.add('scale-95');
                setTimeout(() => {
                    modal.classList.add('hidden');
                }, 300);
            }
        }

        function openEditModal(product) {
            document.getElementById('editForm').action = '/admin/products/edit/' + product.id;
            document.getElementById('edit_name').value = product.name;
            document.getElementById('edit_description').value = product.description;
            document.getElementById('edit_price').value = product.price_points;
            document.getElementById('edit_image').value = product.image_url || '';
            toggleModal('editModal');
        }
    </script>
</body>
</html>