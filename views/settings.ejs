<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kontrol Paneli (Ayarlar) | Sporthink Gamification</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        body { background-color: #0f172a; color: #f8fafc; }
        .glass-panel { background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 1rem; }
    </style>
</head>
<body class="flex h-screen overflow-hidden text-slate-200">
    <!-- SOL MENÜ -->
    <aside class="w-64 bg-slate-900 border-r border-slate-700 flex flex-col hidden md:flex">
        <div class="h-16 flex items-center justify-center border-b border-slate-700">
            <h1 class="text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-teal-400 to-blue-500">Sporthink Panel</h1>
        </div>
                        <nav class="flex-1 p-4 space-y-2 overflow-y-auto">
            <a href="/admin" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-home w-6"></i> Dashboard</a>
            <a href="/admin/products" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-shopping-bag w-6"></i> Ürünler (Dükkan)</a>
            <a href="/admin/chests" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-box-open w-6"></i> Sandık Sistemi</a>
            <a href="/admin/users" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-users w-6"></i> Kullanıcılar</a>
            <a href="/admin/stats" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-chart-line w-6"></i> İstatistik ve Loglar</a>
            <a href="/admin/notifications" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-bell w-6"></i> Bildirimler</a>
            <a href="/admin/tips" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-lightbulb w-6"></i> İpuçları (Tips)</a>
            <a href="/admin/settings" class="flex items-center px-4 py-3 bg-gradient-to-r from-teal-500/20 to-blue-500/20 text-teal-300 border border-teal-500/30 rounded-lg transition-colors"><i class="fas fa-cogs w-6"></i> Ayarlar</a>
            <a href="/admin/badges" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-award w-6"></i> Rozetler (Badges)</a>
            <a href="/admin/avatar-items" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-user-astronaut w-6"></i> Avatar Parçaları</a>
            <a href="/admin/admins" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-user-shield w-6"></i> Admin Yönetimi</a>
        </nav>
    </aside>

    <!-- ANA İÇERİK -->
    <main class="flex-1 flex flex-col bg-slate-900 overflow-y-auto relative">
        <header class="h-16 flex items-center justify-between px-8 border-b border-slate-700 glass-panel sticky top-0 z-10 rounded-none border-t-0 border-l-0 border-r-0">
            <h2 class="text-xl font-semibold"><i class="fas fa-sliders-h mr-2 text-purple-400"></i> Kontrol Paneli</h2>
            <div class="flex items-center space-x-4">
                <span class="text-sm text-slate-400"><i class="fas fa-user-shield mr-1"></i> Admin</span>
                <a href="/admin/logout" class="text-sm text-red-400 hover:text-red-300 transition-colors">
                    <i class="fas fa-sign-out-alt mr-1"></i> Çıkış
                </a>
            </div>
        </header>

        <div class="p-8 space-y-6">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <!-- Settings Form -->
                <div class="lg:col-span-2 glass-panel p-6 border border-slate-700 h-fit">
                    <h5 class="text-lg font-bold mb-6 text-white border-b border-slate-700 pb-3 flex items-center">
                        <i class="fas fa-microchip mr-2 text-blue-400"></i> Sistem Algoritması ve Fiyatlar
                    </h5>

                    <form action="/admin/settings/update" method="POST" class="space-y-6">
                        <!-- Steps Config -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-medium text-slate-300 mb-1">Adım 👉 Puan Dönüşümü (Kaç Adım = 1 Puan)</label>
                                <input type="number" name="steps_per_point" value="<%= settings.steps_per_point || 100 %>" required class="w-full bg-slate-900 border border-slate-600 rounded px-3 py-2 text-white focus:outline-none focus:border-blue-500">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-300 mb-1 text-red-400"><i class="fas fa-shield-alt mr-1"></i> Anti-Cheat: Max Adım Sınırı</label>
                                <input type="number" name="max_steps_per_day" value="<%= settings.max_steps_per_day || 50000 %>" required class="w-full bg-slate-900 border border-red-900/50 rounded px-3 py-2 text-white focus:outline-none focus:border-red-500">
                                <p class="text-xs text-slate-500 mt-1">Bu adım sayısının üzeri hile sayılarak engellenir.</p>
                            </div>
                        </div>


                        <!-- Anti-Cheat Config -->
                        <div class="bg-slate-800/50 border border-red-500/30 rounded-lg p-4">
                            <h6 class="text-sm font-bold text-red-400 mb-3"><i class="fas fa-shield-alt mr-1"></i> Anti-Cheat Sistemi</h6>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-sm font-medium text-slate-300 mb-1">Anti-Cheat Durumu</label>
                                    <select name="anticheat_enabled" class="w-full bg-slate-900 border border-red-900/50 rounded px-3 py-2 text-white focus:outline-none focus:border-red-500">
                                        <option value="1" <%= settings.anticheat_enabled == '1' || !settings.anticheat_enabled ? 'selected' : '' %>>Aktif</option>
                                        <option value="0" <%= settings.anticheat_enabled == '0' ? 'selected' : '' %>>Devre Disi (Test)</option>
                                    </select>
                                    <p class="text-xs text-slate-500 mt-1">Kapatinca cihaz kilidi ve adim limiti devre disi kalir.</p>
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-slate-300 mb-1">Cihaz Kilitlerini Temizle</label>
                                    <a href="/admin/settings/clear-device-locks" onclick="return confirm('Tum kilitleri silmek?')" class="block w-full text-center bg-red-900/30 border border-red-500/30 hover:bg-red-800/50 text-red-300 rounded px-3 py-2 transition-colors text-sm">
                                        <i class="fas fa-unlock mr-1"></i> Kilitleri Sifirla
                                    </a>
                                    <p class="text-xs text-slate-500 mt-1">Test icin haftalik cihaz baglantilarini temizler.</p>
                                </div>
                            </div>
                        </div>
                        <!-- Chest Pricing -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-medium text-blue-400 mb-1"><i class="fas fa-sun mr-1"></i> Günlük Sandık Maliyeti (Puan)</label>
                                <input type="number" name="daily_chest_price_points" value="<%= settings.daily_chest_price_points || 0 %>" required class="w-full bg-slate-900 border border-blue-900/50 rounded px-3 py-2 text-white focus:outline-none focus:border-blue-500">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-yellow-400 mb-1"><i class="fas fa-calendar-week mr-1"></i> Haftalık Sandık Maliyeti (Puan)</label>
                                <input type="number" name="weekly_chest_price_points" value="<%= settings.weekly_chest_price_points || 500 %>" required class="w-full bg-slate-900 border border-yellow-900/50 rounded px-3 py-2 text-white focus:outline-none focus:border-yellow-500">
                            </div>
                        </div>

                        // Streak Config
                        <div class="bg-slate-800/50 border border-slate-700 rounded-lg p-4">
                            <label class="block text-sm font-bold text-orange-400 mb-2"><i class="fas fa-fire mr-1"></i> Gün Serisi (Streak) Minimum Adım</label>
                            <input type="number" name="streak_min_steps" value="<%= settings.streak_min_steps || 5000 %>" required class="w-full bg-slate-900 border border-slate-600 rounded px-3 py-2 text-white focus:outline-none focus:border-orange-500">
                            <p class="text-xs text-slate-400 mt-2">Oyuncunun bir günlük (streak) seriyi uzatabilmesi için senkronize etmesi gereken en az adım miktarı.</p>
                        </div>

                        <!-- Level & XP Config -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="bg-slate-800/50 border border-purple-500/30 rounded-lg p-4">
                                <label class="block text-sm font-bold text-purple-400 mb-2"><i class="fas fa-level-up-alt mr-1"></i> XP Zorluk Çarpanı</label>
                                <input type="number" name="xp_difficulty_modifier" value="<%= settings.xp_difficulty_modifier || 250 %>" required class="w-full bg-slate-900 border border-purple-900/50 rounded px-3 py-2 text-white focus:outline-none focus:border-purple-500">
                                <p class="text-xs text-slate-400 mt-2">Level atlama zorluğu. Varsayılan 250. Daha yüksek sayı = daha zor level atlama.</p>
                            </div>
                            <div class="bg-slate-800/50 border border-green-500/30 rounded-lg p-4">
                                <label class="block text-sm font-bold text-green-400 mb-2"><i class="fas fa-gift mr-1"></i> Level Atlama Puan Ödülü</label>
                                <input type="number" name="level_up_points_reward" value="<%= settings.level_up_points_reward || 100 %>" required class="w-full bg-slate-900 border border-green-900/50 rounded px-3 py-2 text-white focus:outline-none focus:border-green-500">
                                <p class="text-xs text-slate-400 mt-2">Kullanıcı her yeni seviyeye ulaştığında otomatik olarak verilecek Puan (P) ödülü.</p>
                            </div>
                        </div>
                        <div class="pt-4 border-t border-slate-700">
                            <h4 class="text-sm font-bold text-cyan-400 mb-4"><i class="fas fa-comment-dots mr-1"></i> Yorum Moderasyon Ayarları</h4>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label class="block text-sm font-medium text-slate-300 mb-1">Maks. Yorum Karakteri</label>
                                    <input type="number" name="max_comment_length" value="<%= settings.max_comment_length || 100 %>" required class="w-full bg-slate-900 border border-cyan-900/50 rounded px-3 py-2 text-white focus:outline-none focus:border-cyan-500">
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-slate-300 mb-1">Günlük Maks. Yorum (Spam Önleme)</label>
                                    <input type="number" name="max_daily_comments" value="<%= settings.max_daily_comments || 50 %>" required class="w-full bg-slate-900 border border-cyan-900/50 rounded px-3 py-2 text-white focus:outline-none focus:border-cyan-500">
                                </div>
                            </div>
                        </div>

                        <div class="pt-4 border-t border-slate-700 text-right">
                            <button type="submit" class="px-6 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium rounded shadow transition-colors inline-flex items-center">
                                <i class="fas fa-save mr-2"></i> Değişiklikleri Kaydet
                            </button>
                        </div>
                    </form>
                </div>

                <!-- Info Card -->
                <div class="lg:col-span-1">
                    <div class="glass-panel p-6 border border-blue-500/30 bg-blue-900/10 h-fit">
                        <h5 class="text-lg font-bold text-blue-400 mb-3 flex items-center">
                            <i class="fas fa-info-circle mr-2"></i> Önemli Bilgi
                        </h5>
                        <p class="text-sm text-slate-300 leading-relaxed">
                            Bu alandan yapılan değişiklikler mobil uygulamadaki adım çevirme algoritmasını <strong class="text-white">anlık olarak</strong> etkiler. Haftalık sandığın veya günlük sandığın puan maliyetlerini değiştirirseniz kullanıcılardan anında o yeni puan kesilecektir.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </main>
</body>
</html>
