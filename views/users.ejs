<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kullanici Yonetimi | Sporthink</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        body { background-color: #0f172a; color: #f8fafc; }
        .glass-panel { background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 1rem; }
        .modal-bg { background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); }
    </style>
</head>
<body class="flex h-screen overflow-hidden text-slate-200">
    <aside class="w-64 bg-slate-900 border-r border-slate-700 flex flex-col hidden md:flex">
        <div class="h-16 flex items-center justify-center border-b border-slate-700">
            <h1 class="text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-teal-400 to-blue-500">Sporthink Panel</h1>
        </div>
                        <nav class="flex-1 p-4 space-y-2 overflow-y-auto">
            <a href="/admin" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-home w-6"></i> Dashboard</a>
            <a href="/admin/products" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-shopping-bag w-6"></i> Ürünler (Dükkan)</a>
            <a href="/admin/chests" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-box-open w-6"></i> Sandık Sistemi</a>
            <a href="/admin/users" class="flex items-center px-4 py-3 bg-gradient-to-r from-teal-500/20 to-blue-500/20 text-teal-300 border border-teal-500/30 rounded-lg transition-colors"><i class="fas fa-users w-6"></i> Kullanıcılar</a>
            <a href="/admin/stats" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-chart-line w-6"></i> İstatistik ve Loglar</a>
            <a href="/admin/notifications" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-bell w-6"></i> Bildirimler</a>
            <a href="/admin/tips" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-lightbulb w-6"></i> İpuçları (Tips)</a>
            <a href="/admin/settings" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-cogs w-6"></i> Ayarlar</a>
            <a href="/admin/badges" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-award w-6"></i> Rozetler (Badges)</a>
            <a href="/admin/avatar-items" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-user-astronaut w-6"></i> Avatar Parçaları</a>
            <a href="/admin/admins" class="flex items-center px-4 py-3 text-slate-300 hover:bg-slate-800 rounded-lg transition-colors"><i class="fas fa-user-shield w-6"></i> Admin Yönetimi</a>
        </nav>
    </aside>
    <main class="flex-1 flex flex-col bg-slate-900 overflow-y-auto">
        <header class="h-16 flex items-center justify-between px-8 border-b border-slate-700 glass-panel sticky top-0 z-10 rounded-none border-t-0 border-l-0 border-r-0">
            <h2 class="text-xl font-semibold"><i class="fas fa-users mr-2 text-emerald-400"></i> Kullanici Yonetimi</h2>
            <a href="/admin/logout" class="text-sm text-red-400 hover:text-red-300"><i class="fas fa-sign-out-alt mr-1"></i> Cikis</a>
        </header>
        <div class="p-8">
            <div class="glass-panel overflow-hidden border border-slate-700">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-slate-800/50 border-b border-slate-700 text-slate-400 text-sm">
                                <th class="p-4 font-medium">ID</th>
                                <th class="p-4 font-medium">Kullanıcı (K.Adı)</th>
                                <th class="p-4 font-medium">E-Posta</th>
                                <th class="p-4 font-medium">Puan</th>
                                <th class="p-4 font-medium">Durum</th>
                                <th class="p-4 font-medium">Kayit</th>
                                <th class="p-4 font-medium text-right">Islemler</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-700/50 text-sm">
                            <% if (users.length === 0) { %>
                                <tr><td colspan="7" class="p-8 text-center text-slate-500 italic">Kullanici yok.</td></tr>
                            <% } else { %>
                                <% users.forEach(user => { %>
                                    <tr class="hover:bg-slate-800/50 transition-colors">
                                        <td class="p-4 text-slate-500 font-mono text-xs"><%= user.id.slice(0,8) %>...</td>
                                        <td class="p-4">
                                            <div class="font-bold text-slate-200"><%= user.first_name %> <%= user.last_name %></div>
                                            <div class="text-xs text-slate-400">@<%= user.username || 'yok' %></div>
                                        </td>
                                        <td class="p-4 text-slate-400"><%= user.email %></td>
                                        <td class="p-4"><span class="bg-emerald-500/20 text-emerald-400 border border-emerald-500/30 px-2 py-1 rounded text-xs font-medium"><i class="fas fa-coins mr-1"></i> <%= user.total_points %></span></td>
                                        <td class="p-4">
                                            <% if (user.is_banned) { %>
                                                <span class="bg-red-500/20 text-red-400 border border-red-500/30 px-2 py-1 rounded text-xs font-medium"><i class="fas fa-ban mr-1"></i> Banli</span>
                                            <% } else { %>
                                                <span class="bg-green-500/20 text-green-400 border border-green-500/30 px-2 py-1 rounded text-xs font-medium"><i class="fas fa-check mr-1"></i> Aktif</span>
                                            <% } %>
                                        </td>
                                        <td class="p-4 text-slate-500 text-xs"><%= new Date(user.created_at).toLocaleDateString('tr-TR') %></td>
                                        <td class="p-4 text-right space-x-2">
                                            <button onclick="openLogsModal('<%= user.id %>', '<%= user.first_name %> <%= user.last_name %>')" class="text-blue-400 bg-blue-500/10 hover:bg-blue-500/20 px-3 py-1.5 rounded border border-blue-500/30" title="Loglar"><i class="fas fa-file-alt"></i></button>
                                            <% if (user.is_banned) { %>
                                                <form action="/admin/users/unban" method="POST" class="inline" onsubmit="return confirm('Bani kaldirmak istediginize emin misiniz?')">
                                                    <input type="hidden" name="user_id" value="<%= user.id %>">
                                                    <button class="text-green-400 bg-green-500/10 hover:bg-green-500/20 px-3 py-1.5 rounded border border-green-500/30"><i class="fas fa-unlock"></i></button>
                                                </form>
                                            <% } else { %>
                                                <button onclick="openBanModal('<%= user.id %>', '<%= user.first_name %> <%= user.last_name %>')" class="text-yellow-400 bg-yellow-500/10 hover:bg-yellow-500/20 px-3 py-1.5 rounded border border-yellow-500/30"><i class="fas fa-ban"></i></button>
                                            <% } %>
                                            <form action="/admin/users/delete" method="POST" class="inline" onsubmit="return confirm('DIKKAT: Bu kullaniciyi kalici olarak silmek istediginize emin misiniz?')">
                                                <input type="hidden" name="user_id" value="<%= user.id %>">
                                                <button class="text-red-400 bg-red-500/10 hover:bg-red-500/20 px-3 py-1.5 rounded border border-red-500/30"><i class="fas fa-trash"></i></button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <!-- Ban Modal -->
    <div id="banModal" class="fixed inset-0 modal-bg hidden z-50 flex items-center justify-center">
        <div class="glass-panel p-6 w-full max-w-md border border-yellow-500/30">
            <h3 class="text-lg font-bold text-yellow-400 mb-4"><i class="fas fa-ban mr-2"></i> Kullaniciyi Banla</h3>
            <p class="text-slate-400 text-sm mb-4">Kullanici: <span id="banUserName" class="text-white font-bold"></span></p>
            <form action="/admin/users/ban" method="POST">
                <input type="hidden" name="user_id" id="banUserId">
                <div class="mb-4">
                    <label class="block text-sm text-slate-300 mb-1">Ban Suresi</label>
                    <select name="duration" required class="w-full bg-slate-900 border border-slate-600 rounded px-3 py-2 text-white">
                        <option value="1">1 Gun</option>
                        <option value="7">7 Gun</option>
                        <option value="30">30 Gun</option>
                        <option value="permanent">Kalici</option>
                    </select>
                </div>
                <div class="mb-4">
                    <label class="block text-sm text-slate-300 mb-1">Sebep</label>
                    <textarea name="reason" required rows="3" maxlength="500" placeholder="Ban sebebini yazin..." class="w-full bg-slate-900 border border-slate-600 rounded px-3 py-2 text-white resize-none"></textarea>
                </div>
                <div class="flex space-x-3">
                    <button type="submit" class="flex-1 bg-yellow-600 hover:bg-yellow-700 text-white py-2 rounded font-bold">Banla</button>
                    <button type="button" onclick="closeBanModal()" class="flex-1 bg-slate-700 hover:bg-slate-600 text-white py-2 rounded">Iptal</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Kullanıcı Log Modal -->
    <div id="logModal" class="fixed inset-0 modal-bg hidden z-50 flex items-center justify-center p-4">
        <div class="glass-panel w-full max-w-4xl max-h-[90vh] overflow-hidden border border-blue-500/30 flex flex-col">
            <div class="flex items-center justify-between px-6 py-4 border-b border-slate-700 bg-slate-900/50">
                <h3 class="text-lg font-bold text-blue-400"><i class="fas fa-file-alt mr-2"></i> <span id="logUserName"></span> - Kullanıcı Logları</h3>
                <button onclick="closeLogModal()" class="text-slate-400 hover:text-white text-xl"><i class="fas fa-times"></i></button>
            </div>

            <!-- User Info Summary -->
            <div id="logUserInfo" class="px-6 py-3 border-b border-slate-700 bg-slate-800/30"></div>

            <!-- Tab Buttons -->
            <div class="flex border-b border-slate-700 px-6">
                <button onclick="switchLogTab('steps')" id="tabSteps" class="px-4 py-3 text-sm font-medium border-b-2 border-blue-500 text-blue-400 transition-colors">
                    <i class="fas fa-walking mr-1"></i> Adım Geçmişi
                </button>
                <button onclick="switchLogTab('points')" id="tabPoints" class="px-4 py-3 text-sm font-medium border-b-2 border-transparent text-slate-400 hover:text-slate-200 transition-colors">
                    <i class="fas fa-coins mr-1"></i> Puan Hareketleri
                </button>
                <button onclick="switchLogTab('badges')" id="tabBadges" class="px-4 py-3 text-sm font-medium border-b-2 border-transparent text-slate-400 hover:text-slate-200 transition-colors">
                    <i class="fas fa-award mr-1"></i> Rozetler
                </button>
            </div>

            <!-- Tab Content -->
            <div class="flex-1 overflow-y-auto p-6">
                <div id="logLoading" class="text-center text-slate-500 py-12">
                    <i class="fas fa-spinner fa-spin text-3xl mb-3 block"></i> Yükleniyor...
                </div>
                <div id="logContentSteps" class="hidden"></div>
                <div id="logContentPoints" class="hidden"></div>
                <div id="logContentBadges" class="hidden"></div>
            </div>
        </div>
    </div>

    <script>
        function openBanModal(userId, userName) {
            document.getElementById('banUserId').value = userId;
            document.getElementById('banUserName').textContent = userName;
            document.getElementById('banModal').classList.remove('hidden');
        }
        function closeBanModal() { document.getElementById('banModal').classList.add('hidden'); }

        function closeLogModal() { document.getElementById('logModal').classList.add('hidden'); }

        function switchLogTab(tab) {
            document.querySelectorAll('[id^="logContent"]').forEach(el => el.classList.add('hidden'));
            document.querySelectorAll('[id^="tab"]').forEach(el => { el.classList.remove('border-blue-500', 'text-blue-400'); el.classList.add('border-transparent', 'text-slate-400'); });

            document.getElementById('logContent' + tab.charAt(0).toUpperCase() + tab.slice(1)).classList.remove('hidden');
            const tabBtn = document.getElementById('tab' + tab.charAt(0).toUpperCase() + tab.slice(1));
            tabBtn.classList.add('border-blue-500', 'text-blue-400');
            tabBtn.classList.remove('border-transparent', 'text-slate-400');
        }

        async function openLogsModal(userId, userName) {
            document.getElementById('logUserName').textContent = userName;
            document.getElementById('logModal').classList.remove('hidden');
            document.getElementById('logLoading').classList.remove('hidden');
            document.querySelectorAll('[id^="logContent"]').forEach(el => { el.classList.add('hidden'); el.innerHTML = ''; });

            try {
                const res = await fetch('/admin/users/logs/' + userId);
                const data = await res.json();
                document.getElementById('logLoading').classList.add('hidden');

                // User Info
                const u = data.user;
                if (u) {
                    document.getElementById('logUserInfo').innerHTML = `
                        <div class="flex flex-wrap gap-4 text-sm">
                            <span class="text-slate-400">@${u.username || '-'}</span>
                            <span class="text-slate-400">${u.email}</span>
                            <span class="text-emerald-400 font-bold"><i class="fas fa-coins mr-1"></i>${u.total_points} Puan</span>
                            <span class="text-blue-400"><i class="fas fa-star mr-1"></i>${u.xp || 0} XP</span>
                            <span class="text-orange-400"><i class="fas fa-fire mr-1"></i>${u.current_streak || 0} Gün Seri</span>
                            <span class="text-slate-500">Kayıt: ${new Date(u.created_at).toLocaleDateString('tr-TR')}</span>
                        </div>
                    `;
                }

                // Steps Tab
                let stepsHtml = '<table class="w-full text-sm text-left"><thead><tr class="text-slate-400 border-b border-slate-700"><th class="pb-2">Tarih</th><th class="pb-2">Adım</th><th class="pb-2">Durum</th></tr></thead><tbody>';
                if (data.steps.length === 0) { stepsHtml = '<p class="text-slate-500 text-center py-8">Adım kaydı bulunamadı.</p>'; }
                else {
                    data.steps.forEach(s => {
                        const status = s.is_suspicious ? '<span class="text-red-400"><i class="fas fa-exclamation-triangle mr-1"></i>Şüpheli</span>' : (s.is_valid ? '<span class="text-green-400"><i class="fas fa-check mr-1"></i>Geçerli</span>' : '<span class="text-yellow-400"><i class="fas fa-times mr-1"></i>Geçersiz</span>');
                        stepsHtml += `<tr class="border-b border-slate-800"><td class="py-2 text-slate-300">${s.day}</td><td class="py-2 font-bold text-white">${s.step_count.toLocaleString('tr-TR')}</td><td class="py-2">${status}</td></tr>`;
                    });
                    stepsHtml += '</tbody></table>';
                }
                document.getElementById('logContentSteps').innerHTML = stepsHtml;

                // Points Tab
                let pointsHtml = '<table class="w-full text-sm text-left"><thead><tr class="text-slate-400 border-b border-slate-700"><th class="pb-2">Tür</th><th class="pb-2">Puan</th><th class="pb-2">Kaynak</th><th class="pb-2">Tarih</th></tr></thead><tbody>';
                if (data.points.length === 0) { pointsHtml = '<p class="text-slate-500 text-center py-8">Puan hareketi bulunamadı.</p>'; }
                else {
                    data.points.forEach(p => {
                        const typeColor = p.type === 'earn' ? 'text-green-400' : 'text-red-400';
                        const typeLabel = p.type === 'earn' ? '+' + p.points : '-' + p.points;
                        pointsHtml += `<tr class="border-b border-slate-800"><td class="py-2"><span class="px-2 py-0.5 rounded text-xs font-bold ${p.type === 'earn' ? 'bg-green-500/20 text-green-400' : 'bg-red-500/20 text-red-400'}">${p.type === 'earn' ? 'Kazanım' : 'Harcama'}</span></td><td class="py-2 font-bold ${typeColor}">${typeLabel}</td><td class="py-2 text-slate-300">${p.source || '-'}${p.ref_id ? ' (' + p.ref_id + ')' : ''}</td><td class="py-2 text-slate-500">${new Date(p.created_at).toLocaleString('tr-TR')}</td></tr>`;
                    });
                    pointsHtml += '</tbody></table>';
                }
                document.getElementById('logContentPoints').innerHTML = pointsHtml;

                // Badges Tab
                let badgesHtml = '';
                if (data.badges.length === 0) { badgesHtml = '<p class="text-slate-500 text-center py-8">Henüz rozet kazanılmamış.</p>'; }
                else {
                    badgesHtml = '<div class="grid grid-cols-2 md:grid-cols-3 gap-3">';
                    data.badges.forEach(b => {
                        badgesHtml += `<div class="bg-slate-800/50 border border-slate-700 rounded-lg p-4 text-center"><i class="fas fa-award text-yellow-400 text-2xl mb-2"></i><p class="text-white font-bold text-sm">${b.name}</p><p class="text-slate-500 text-xs mt-1">${new Date(b.earned_at).toLocaleDateString('tr-TR')}</p></div>`;
                    });
                    badgesHtml += '</div>';
                }
                document.getElementById('logContentBadges').innerHTML = badgesHtml;

                // Show first tab
                switchLogTab('steps');
            } catch (err) {
                document.getElementById('logLoading').innerHTML = '<p class="text-red-400">Loglar yüklenirken hata oluştu.</p>';
            }
        }
    </script>
</body>
</html>
